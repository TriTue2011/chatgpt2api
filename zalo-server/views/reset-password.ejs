<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Reset mật khẩu Admin | Zalo Chat</title>
    <meta name="theme-color" content="#0068ff">
    <link rel="icon" type="image/png" href="<%= ingressPath %>/chat/icons/icon-192.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="<%= ingressPath %>/chat/css/app.css">
    <style>
        .reset-card { max-width: 460px; margin: 0 auto; text-align: center; }
    </style>
</head>
<body>

<header class="app-header">
    <a href="<%= ingressPath %>/" class="app-logo">
        <span class="app-logo-icon"><img src="<%= ingressPath %>/chat/icons/icon-192.png" style="width:100%;height:100%;border-radius:8px;object-fit:cover"></span>
        Zalo Chat
    </a>
    <div class="header-spacer"></div>
    <div class="header-actions">
        <button class="btn-icon" id="theme-toggle" aria-label="Đổi theme">🌙</button>
    </div>
</header>

<main class="container container-sm">
    <h1 class="page-title">Reset mật khẩu Admin</h1>
    <p class="page-subtitle">Đặt lại mật khẩu tài khoản admin về mặc định</p>

    <div class="card reset-card">
        <div class="card-body">
            <div class="alert alert-warning" style="text-align:left">
                <span>⚠️</span>
                <span>Hành động này sẽ đặt lại mật khẩu của tài khoản <strong>admin</strong> về giá trị mặc định <strong>"admin"</strong>.</span>
            </div>
            <button id="resetButton" class="btn btn-danger btn-lg">Reset mật khẩu Admin</button>
            <div id="successMessage" class="alert alert-success" style="display:none;margin-top:16px">Đã reset mật khẩu admin thành công! Bạn có thể đăng nhập với mật khẩu "admin".</div>
            <div id="errorMessage" class="alert alert-error" style="display:none;margin-top:16px"></div>
        </div>
    </div>

    <div class="text-center mt-3">
        <a href="<%= ingressPath %>/" class="btn btn-outline">← Quay lại trang chủ</a>
    </div>
</main>

<script>
    var INGRESS_PATH = '<%= ingressPath %>';
(function() {
    var s = localStorage.getItem('chat-theme');
    if (s) document.documentElement.setAttribute('data-theme', s);
    else if (window.matchMedia('(prefers-color-scheme: dark)').matches) document.documentElement.setAttribute('data-theme', 'dark');
    var btn = document.getElementById('theme-toggle');
    function up() { btn.textContent = document.documentElement.getAttribute('data-theme') === 'dark' ? '☀️' : '🌙'; }
    up();
    btn.addEventListener('click', function() {
        var cur = document.documentElement.getAttribute('data-theme');
        var next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('chat-theme', next);
        up();
    });
})();

document.getElementById('resetButton').addEventListener('click', async function() {
    try {
        var r = await fetch(INGRESS_PATH + '/api/reset-admin-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        var d = await r.json();
        if (r.ok) {
            document.getElementById('successMessage').style.display = 'flex';
            document.getElementById('errorMessage').style.display = 'none';
            this.disabled = true;
        } else {
            document.getElementById('errorMessage').textContent = d.error || 'Đã xảy ra lỗi khi reset mật khẩu.';
            document.getElementById('errorMessage').style.display = 'flex';
            document.getElementById('successMessage').style.display = 'none';
        }
    } catch (ex) {
        document.getElementById('errorMessage').textContent = 'Lỗi kết nối máy chủ.';
        document.getElementById('errorMessage').style.display = 'flex';
    }
});
</script>

</body>
</html>
